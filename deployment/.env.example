# Production Deployment Environment Variables
# Copy this file to .env and fill in your actual values

# PostgreSQL Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=overpacked

# Backend Configuration
APP_USERNAME=admin
APP_PASSWORD=changeme
JWT_SECRET=your-random-jwt-secret-min-32-chars
SERVER_ADDR=0.0.0.0:8000

# Directory where item images are stored on disk. Backed by the
# overpacked_uploads volume in docker-compose so images survive restarts.
IMAGES_DIR=/app/uploads

# Frontend reverse proxy upstream.
# If backend service/container is renamed, set this to the reachable name and port.
BACKEND_UPSTREAM=backend:8000
